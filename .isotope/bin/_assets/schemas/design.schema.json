{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isotope://schema/design/1",
  "title": "Isotope specimen design",
  "type": "object",
  "required": ["context", "acceptance_criteria", "changes", "verification"],
  "properties": {
    "context": {"type": "string", "minLength": 1},
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "criterion"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "pattern": "^AC[1-9][0-9]*$"},
          "criterion": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["schema_version", "number", "title", "files", "steps", "tests", "commit"],
        "properties": {
          "schema_version": {"const": "2"},
          "number": {"type": "integer", "minimum": 1},
          "title": {"type": "string", "minLength": 1},
          "files": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "steps": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "tests": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "commit": {"type": "string", "minLength": 1},
          "model": {"enum": ["sonnet", "opus", "fable"]},
          "inline": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "instruction"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "pattern": "^V[1-9][0-9]*$"},
          "instruction": {"type": "string", "minLength": 1},
          "gate_id": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
