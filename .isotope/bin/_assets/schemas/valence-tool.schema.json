{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isotope://schema/valence-tool/1",
  "title": "Isotope Valence tool descriptor",
  "type": "object",
  "required": ["schema_version", "name", "description", "evidence", "input", "command", "effect", "authority", "validation"],
  "properties": {
    "schema_version": {"const": "1"},
    "name": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "description": {"type": "string", "minLength": 1},
    "evidence": {"type": "array", "items": {"type": "string", "minLength": 1, "pattern": "^Q[1-9][0-9]*$"}, "minItems": 1, "uniqueItems": true},
    "input": {
      "type": "object",
      "required": ["parameters"],
      "properties": {"parameters": {"type": "object"}},
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "required": ["argv"],
      "properties": {"argv": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}},
      "additionalProperties": false
    },
    "effect": {"enum": ["read-only", "repo-write"]},
    "authority": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "validation": {
      "type": "object",
      "required": ["argv", "expect_exit"],
      "properties": {
        "argv": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
        "expect_exit": {"type": "integer"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
