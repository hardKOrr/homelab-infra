{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isotope://schema/acceptance/2",
  "title": "Isotope whole-specimen acceptance",
  "type": "object",
  "required": ["schema_version", "id", "number", "verdict", "abstract", "criteria", "verification", "findings"],
  "properties": {
    "schema_version": {"const": "2"},
    "id": {"type": "string", "pattern": "^A[1-9][0-9]*$"},
    "number": {"type": "integer", "minimum": 1},
    "verdict": {"enum": ["PASS", "CHANGES"]},
    "abstract": {"type": "string", "minLength": 1},
    "criteria": {"type": "array", "items": {"type": "object", "required": ["criterion_id", "status", "evidence"], "properties": {"criterion_id": {"type": "string", "pattern": "^AC[1-9][0-9]*$"}, "status": {"enum": ["PASS", "FAIL"]}, "evidence": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
    "verification": {"type": "array", "items": {"type": "object", "required": ["verification_id", "status", "evidence"], "properties": {"verification_id": {"type": "string", "pattern": "^V[1-9][0-9]*$"}, "status": {"enum": ["PASS", "FAIL"]}, "evidence": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
    "findings": {"type": "array", "items": {"type": "object", "required": ["change", "text"], "properties": {"change": {"type": "integer", "minimum": 1}, "text": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
    "acceptance_snapshot": {"type": "object", "required": ["schema_version", "base_commit", "head_commit", "index", "tracked", "untracked"], "properties": {"schema_version": {"const": "1"}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "head_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "index": {"type": "array"}, "tracked": {"type": "array"}, "untracked": {"type": "array"}}, "additionalProperties": false},
    "invocation_id": {"type": "string", "pattern": "^I[1-9][0-9]*$"},
    "reaction_protocol_version": {"type": "string", "minLength": 1},
    "source_revisions": {"type": "object"},
    "actor": {"type": "object", "required": ["host", "model", "reaction"], "properties": {"host": {"enum": ["claude", "codex"]}, "model": {"type": ["string", "null"]}, "reaction": {"const": "acceptance"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
