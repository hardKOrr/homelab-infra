{
  "schema_version": "1",
  "id": "review",
  "version": "1",
  "coordinates": {
    "required": ["slug", "change", "round"],
    "properties": {
      "slug": "string",
      "change": "integer",
      "round": "integer"
    }
  },
  "brief_map": "brief.map.json",
  "readout_schema": "readout.schema.json",
  "entity_schema": "../../schemas/assay.schema.json",
  "allowed_effects": ["specimen.assay.append"],
  "authority": {
    "catalyst": "read-only",
    "broker": "completion-capability",
    "capability_custody": "controlling-wrapper-only"
  },
  "outcomes": ["PASS", "CHANGES"],
  "terminal_statuses": ["complete", "needs-user", "blocked", "refused", "failed"],
  "assets": {
    "review_agent": {
      "claude": "isotope-review",
      "codex": "isotope_review"
    },
    "operate_owner": {
      "claude": "isotope-operate",
      "codex": "isotope-operate"
    }
  },
  "result_destination": "/assays"
}
